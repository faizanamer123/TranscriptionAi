# Copy to .env and set your token (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Diarization models
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_FALLBACK_MODEL=pyannote/speaker-diarization-community-1

# Speaker bounds (single effective value; do not duplicate)
DIARIZATION_MIN_SPEAKERS=1
DIARIZATION_MAX_SPEAKERS=30
# DIARIZATION_MAX_SPEAKERS=none

# VAD / boundary cleanup
DIARIZATION_SILERO_VAD=1
DIARIZATION_SILERO_PAD_MS=40
DIARIZATION_RESEGMENT_SMOOTH=1
DIARIZATION_RESEGMENT_MERGE_GAP_SEC=0.08
DIARIZATION_RESEGMENT_ISLAND_SEC=0.3
DIARIZATION_USE_EXCLUSIVE=1

# Embeddings / clustering
DIARIZATION_EMBEDDING_EXCLUDE_OVERLAP=1
DIARIZATION_SEGMENTATION_THRESHOLD=0.55
DIARIZATION_MIN_DURATION_OFF=0.5
DIARIZATION_CLUSTERING_THRESHOLD=0.65
DIARIZATION_VBX_FA=0.07
DIARIZATION_VBX_FB=0.8

# Word-speaker assignment
TRANSCRIPT_ASSIGN_FILL_NEAREST=0
TRANSCRIPT_RESOLVE_UNKNOWN=1
TRANSCRIPT_RESOLVE_WINDOW_SEC=4.5
TRANSCRIPT_RESOLVE_MAX_PASSES=5

# Merge / smoothing
TRANSCRIPT_MERGE_MAX_GAP_SEC=1.1
TRANSCRIPT_MAX_SEGMENT_SEC=3.5
TRANSCRIPT_MIN_SPEAKER_TURN_SEC=1.2
TRANSCRIPT_MERGE_ALLOW_MICRO_FLIP=0
TRANSCRIPT_SMOOTH_SPEAKERS=1
TRANSCRIPT_SMOOTH_RADIUS=1
TRANSCRIPT_SMOOTH_PASSES=1
TRANSCRIPT_COLLAPSE_ISLANDS=1
TRANSCRIPT_ISLAND_MAX_SEC=0.45
TRANSCRIPT_CLEAN_ORPHANS=0
TRANSCRIPT_ORPHAN_MIN_DURATION_SEC=0.5

# Temporal anti-jitter glue
TRANSCRIPT_TEMPORAL_GLUE=1
TRANSCRIPT_TEMPORAL_GLUE_MAX_GAP_SEC=0.25
TRANSCRIPT_TEMPORAL_GLUE_ULTRA_GAP_SEC=0.08
TRANSCRIPT_TEMPORAL_GLUE_SHORT_SEC=0.8
TRANSCRIPT_TEMPORAL_GLUE_LONG_CAP_SEC=2.2

